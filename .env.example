# ──────────────────────────────────────────────────────────
# Trade Opportunities API — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────
# Comma-separated list of valid API keys.
# Default dev keys are already baked in; add your own here.
VALID_API_KEYS=dev-key-12345,test-key-67890,your-custom-key-here

# ── Google Gemini ─────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
# Leave blank to use the built-in mock report generator.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=30

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# ── DuckDuckGo ────────────────────────────────────────────
DDGO_TIMEOUT_SECONDS=8

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
